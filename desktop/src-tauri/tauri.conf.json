{
  "productName": "HearthHall Tracker",
  "version": "1.0.0",
  "identifier": "com.tandem.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "HearthHall Tracker",
        "width": 400,
        "height": 360,
        "resizable": false,
        "center": true,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2MDIzQkE3OTgyQ0I2QkEKUldTNnRpeVlwenNDTmpmR2RDQmYzWlgvZFhmUXZsd1ovK3hHZmNCZFlza0FWelYwa2V6Tk9aMG0K",
      "endpoints": [
        "https://almar-t.github.io/tandem/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
